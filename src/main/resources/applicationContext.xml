<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:p="http://www.springframework.org/schema/p"
       xmlns:c="http://www.springframework.org/schema/c"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean id="itemBean" class="org.example.springcore.WithXMLConfiguration.Item" p:name="iPhone" p:price="999.0"/>

    <bean id="storeSI" class="org.example.springcore.WithXMLConfiguration.Store" p:item-ref="itemBean"/>

    <bean id="storeCI" class="org.example.springcore.WithXMLConfiguration.Store" c:item-ref="itemBean"/>
</beans>